{
  "name": "@loopstorm/mcp-proxy",
  "version": "0.1.0",
  "description": "LoopStorm Guard MCP proxy — intercepts MCP tools/call for enforcement",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "loopstorm-mcp-proxy": "./bin/loopstorm-mcp-proxy.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist", "bin"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "bun test",
    "lint": "biome check src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@loopstorm/ipc-client": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.10.0",
    "yaml": "^2.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "*",
    "@types/node": "^25.5.0",
    "tsup": "^8.3.5",
    "typescript": "*"
  },
  "keywords": ["ai", "agent", "safety", "enforcement", "loopstorm", "mcp", "proxy"],
  "repository": {
    "type": "git",
    "url": "https://github.com/loopstorm/loopstorm-guard"
  }
}
