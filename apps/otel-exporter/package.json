{
  "name": "@loopstorm/otel-exporter",
  "version": "0.1.0",
  "description": "LoopStorm Guard OTel exporter — converts JSONL audit events to OpenTelemetry traces",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "loopstorm-otel-export": "./bin/loopstorm-otel-export.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist", "bin"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "bun test",
    "lint": "biome check src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.57.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/semantic-conventions": "^1.30.0"
  },
  "devDependencies": {
    "@biomejs/biome": "*",
    "@types/node": "^25.5.0",
    "tsup": "^8.3.5",
    "typescript": "*"
  },
  "keywords": ["ai", "agent", "safety", "enforcement", "loopstorm", "opentelemetry", "otel", "traces"],
  "repository": {
    "type": "git",
    "url": "https://github.com/loopstorm/loopstorm-guard"
  }
}
