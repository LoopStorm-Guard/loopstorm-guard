# LoopStorm Guard — local development environment variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is gitignored.
#
# Supabase local dev values (from: bunx supabase status)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=<from: bunx supabase status>
SUPABASE_SERVICE_ROLE_KEY=<from: bunx supabase status>

# Better Auth (ADR-011) — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-32-byte-random-secret

# Mailpit local SMTP (Better Auth OTP)
# Start Mailpit: docker run -d --name mailpit -p 1025:1025 -p 8025:8025 axllent/mailpit
SMTP_HOST=localhost
SMTP_PORT=1025

# AI Supervisor (ADR-012) — only needed if running supervisor locally
ANTHROPIC_API_KEY=<your-anthropic-api-key>
SUPERVISOR_MODEL=claude-haiku-4-5-20251001
SUPERVISOR_BUDGET_HARD_USD=2.00

# Engine settings (Mode 0: disable HTTP sink so no backend needed)
LOOPSTORM_DISABLE_HTTP_SINK=1

# Vercel cron secret (only needed for local cron endpoint testing)
VERCEL_CRON_SECRET=dev-cron-secret-not-real
