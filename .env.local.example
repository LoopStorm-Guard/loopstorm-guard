# LoopStorm Guard — local development environment variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is gitignored.
#
# Supabase local dev values (from: bunx supabase status)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=<from: bunx supabase status>

# Better Auth (ADR-011) — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-32-byte-random-secret
# Production: set to the public API URL (used in email links + OAuth redirects).
# Must match the Vercel deployment URL, e.g. https://api.loop-storm.com
BETTER_AUTH_URL=http://localhost:3001

# Mailpit local SMTP (Better Auth OTP)
# Start Mailpit: docker run -d --name mailpit -p 1025:1025 -p 8025:8025 axllent/mailpit
SMTP_HOST=localhost
SMTP_PORT=1025

# CORS allowed origins (T2 Wave 2 security fix)
# Purpose: Comma-separated list of browser origins allowed to make cross-origin
#          requests to the API. Required in production — server fails to boot if
#          this is missing or empty when NODE_ENV=production.
#
# IMPORTANT (production): This value is shared by two mechanisms:
#   1. Hono CORS middleware — adds Access-Control-Allow-Origin to responses
#   2. Better Auth trustedOrigins — CSRF check on every state-mutating request
# Both must allow the frontend origin or auth will fail with a CORS/403 error.
#
# Format:  Comma-separated origin URLs (protocol+host+optional port, no trailing slash)
# Example: ALLOWED_ORIGINS=https://app.loop-storm.com
# In local dev, omit this variable — both the Hono CORS middleware and Better
# Auth trustedOrigins fall back to http://localhost:3000 automatically.
#ALLOWED_ORIGINS=https://app.loop-storm.com

# AI Supervisor LLM API key (ADR-017 Wave 2 rename)
# Purpose: API key for the DeepSeek LLM provider used by the AI Supervisor.
#          In Mode 3 SaaS this is your DeepSeek key; in Mode 1 with Anthropic
#          override, this is your Anthropic key.
# Format:  sk-... (DeepSeek format) or sk-ant-... (Anthropic format)
# Note:    ANTHROPIC_API_KEY is deprecated but still accepted as a fallback.
#          Rename to LOOPSTORM_LLM_API_KEY to suppress the deprecation warning.
LOOPSTORM_LLM_API_KEY=sk-your-deepseek-key-here
# ANTHROPIC_API_KEY=<deprecated — use LOOPSTORM_LLM_API_KEY instead>

SUPERVISOR_BUDGET_HARD_USD=2.00

# Engine settings (Mode 0: disable HTTP sink so no backend needed)
LOOPSTORM_DISABLE_HTTP_SINK=1
