# LoopStorm Guard — local development environment variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is gitignored.
#
# Supabase local dev values (from: bunx supabase status)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=<from: bunx supabase status>

# Better Auth (ADR-011) — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-32-byte-random-secret

# Mailpit local SMTP (Better Auth OTP)
# Start Mailpit: docker run -d --name mailpit -p 1025:1025 -p 8025:8025 axllent/mailpit
SMTP_HOST=localhost
SMTP_PORT=1025

# AI Supervisor (ADR-017) — DeepSeek V3.2 via OpenAI-compatible API.
# Only needed if running the supervisor locally.
# Model is pinned in provider code per ADR-017; do not set SUPERVISOR_MODEL here.
ANTHROPIC_API_KEY=<your-deepseek-api-key>
SUPERVISOR_BUDGET_HARD_USD=2.00

# Engine settings (Mode 0: disable HTTP sink so no backend needed)
LOOPSTORM_DISABLE_HTTP_SINK=1
