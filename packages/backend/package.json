{
  "name": "@loopstorm/api",
  "version": "0.1.0",
  "description": "LoopStorm Guard backend API — Hono + Bun + Drizzle ORM (AGPL-3.0-only)",
  "license": "AGPL-3.0-only",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "test": "bun test",
    "lint": "biome check src/",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@hono/trpc-server": "^0.3.3",
    "@loopstorm/schemas": "*",
    "@trpc/server": "^11.0.0",
    "better-auth": "^1.2.5",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.6.16",
    "picomatch": "^4.0.2",
    "postgres": "^3.4.5",
    "resend": "^6.11.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "*",
    "@types/picomatch": "^4.0.3",
    "drizzle-kit": "^0.30.1",
    "typescript": "*",
    "@types/bun": "latest"
  }
}
