{
  "version": 2,
  "framework": null,
  "installCommand": "bun install --frozen-lockfile",
  "buildCommand": "",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.ts" }
  ],
  "crons": [
    {
      "path": "/api/internal/cron/timeout-checker",
      "schedule": "* * * * *"
    }
  ],
  "functions": {
    "api/**/*.ts": {
      "memory": 512,
      "maxDuration": 60
    }
  },
  "regions": ["iad1"]
}
