# LoopStorm Guard Web UI — Environment Variables
#
# Copy this file to .env.local and fill in the values for local development.
# In production, set these as environment variables in your deployment platform.

# Backend API URL.
# Empty string = use Next.js rewrites (development proxy to localhost:3001).
# Production: set to absolute backend URL, e.g. https://api.loop-storm.com
NEXT_PUBLIC_API_URL=

# Better Auth base URL.
# Empty string = use Next.js rewrites (development proxy to localhost:3001).
# Production: set to absolute backend URL, e.g. https://api.loop-storm.com
NEXT_PUBLIC_BETTER_AUTH_URL=
