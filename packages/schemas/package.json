{
  "name": "@loopstorm/schemas",
  "version": "0.1.0",
  "description": "LoopStorm Guard JSON schemas — single source of truth for IPC, events, and policy (ADR-003)",
  "license": "MIT",
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "bun": "./index.ts",
      "import": "./index.js",
      "types": "./index.d.ts"
    },
    "./policy": "./policy/policy.schema.json",
    "./ipc/decision-request": "./ipc/decision-request.schema.json",
    "./ipc/decision-response": "./ipc/decision-response.schema.json",
    "./events": "./events/event.schema.json"
  },
  "files": ["**/*.json", "types/**/*.ts", "index.ts", "index.js", "index.d.ts"],
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "biome check index.ts types/",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "*",
    "typescript": "*"
  }
}
