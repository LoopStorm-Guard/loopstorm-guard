{
  "name": "@loopstorm/ipc-client",
  "version": "0.1.0",
  "description": "LoopStorm Guard IPC client — UDS NDJSON connection to the enforcement engine",
  "license": "MIT",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "bun test",
    "lint": "biome check src/",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "*",
    "@types/node": "^25.5.0",
    "tsup": "^8.3.5",
    "typescript": "*"
  },
  "keywords": ["ai", "agent", "safety", "enforcement", "loopstorm", "ipc"],
  "repository": {
    "type": "git",
    "url": "https://github.com/loopstorm/loopstorm-guard"
  }
}
